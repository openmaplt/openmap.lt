# PostgreSQL konfigūracija
POSTGRES_USER=openmap
POSTGRES_PASSWORD=openmap
POSTGRES_DB=openmap
POSTGRES_HOST=localhost
POSTGRES_PORT=5432

# Database URL (naudojamas Node.js programoje)
# Development (kai PostgreSQL veikia per docker-compose):
DATABASE_URL=postgresql://openmap:openmap@localhost:5432/openmap

# Svetainės bazinis URL (lokaliai - localhost, produkcijoje - https://openmap.lt)
BASE_URL=http://localhost:3000

# STVK API (saugomų teritorijų duomenys imami tiesiai iš kadastro)
# Nenustačius naudojamas testinis serveris https://test.stvk.lt
STVK_API_URL=https://test.stvk.lt

# Production (kai PostgreSQL veikia host mašinoje, o app Docker konteineryje):
# DATABASE_URL=postgresql://openmap:openmap@host.docker.internal:5432/openmap

# OSM OAuth2 (registruokite: https://www.openstreetmap.org/oauth2/applications)
OSM_CLIENT_ID=
OSM_CLIENT_SECRET=

# Google OAuth2 (registruokite: https://console.cloud.google.com/apis/credentials)
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
